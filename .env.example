# URL da API (back-end) — OBRIGATORIO em producao no Railway!
# Copie a URL do servico "server" no Railway e cole aqui antes de buildar,
# ou configure como variavel de ambiente no servico frontend do Railway.
#
# Exemplo de producao:
# VITE_API_URL=https://atacadao-server-production.up.railway.app
#
# Em desenvolvimento local:
VITE_API_URL=http://localhost:3333
