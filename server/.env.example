# Porta da API (Railway injeta automaticamente)
PORT=3333
NODE_ENV=development

# PostgreSQL - no Railway use a variavel DATABASE_URL do plugin Postgres
DATABASE_URL=postgresql://usuario:senha@localhost:5432/atacadao

# Segredo do JWT - gere um valor aleatorio forte em producao
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=12h

# CORS - dominio do front em producao (separe varios por virgula). Use * em dev.
CORS_ORIGIN=*

# Login unico do sistema (criado automaticamente)
SEED_ADMIN_NAME=Atacadao
SEED_ADMIN_USER=atacadao
SEED_ADMIN_PASSWORD=atacadao123
