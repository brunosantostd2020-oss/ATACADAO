{
  "name": "atacadao-cervejaria-api",
  "version": "1.0.0",
  "description": "Back-end do sistema de comandas do Atacadao Cervejaria",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
